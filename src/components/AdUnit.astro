---
interface Props {
  slot: string;
  format?: 'auto' | 'rectangle' | 'horizontal';
}

const { slot, format = 'auto' } = Astro.props;
const client = 'ca-pub-4614903166174822';
---

<div class="ad-wrap">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={client}
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive="true"
  ></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>

<style>
  .ad-wrap {
    margin: 2rem 0;
    text-align: center;
    min-height: 90px;
  }
</style>
