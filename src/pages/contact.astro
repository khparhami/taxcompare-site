---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Australian Tax Calculator"
  description="Get in touch with the Australian Tax Calculator team. Report a bug, suggest a feature, or ask a question."
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles.css" />
  </Fragment>

  <main class="container">

    <section class="card">
      <h2>Contact Us</h2>
      <p>
        Have a question, spotted an error, or want to suggest a new feature?
        We'd love to hear from you. Fill in the form below and we'll get back to you as soon as possible.
      </p>
    </section>

    <section class="card form-card">
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        id="contact-form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" placeholder="Your name" required autocomplete="name" />
        </div>

        <div class="form-group">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email" />
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <select id="subject" name="subject">
            <option value="bug">Bug or calculation error</option>
            <option value="feature">Feature suggestion</option>
            <option value="tax-question">Tax question</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" placeholder="Describe your question or feedback..." required></textarea>
        </div>

        <button type="submit" class="btn-primary">Send Message</button>
      </form>

      <div id="form-success" class="success-msg" hidden>
        <span class="success-icon">✓</span>
        <div>
          <strong>Message sent!</strong>
          <p>Thanks for reaching out. We'll get back to you shortly.</p>
        </div>
      </div>
    </section>

    <section class="card info-card">
      <h3>Before you write</h3>
      <ul class="info-list">
        <li>
          <strong>Tax calculation questions</strong> — check the
          <a href="/how-the-tax-calculator-works/">How It Works</a> page or the
          <a href="/faq/">FAQ</a> first. Most common questions are answered there.
        </li>
        <li>
          <strong>Official tax advice</strong> — we can't provide personalised tax advice.
          For that, contact the ATO on 13 28 61 or speak with a registered tax agent.
        </li>
        <li>
          <strong>Bug reports</strong> — please include the salary, tax year, and options
          you selected so we can reproduce the issue.
        </li>
      </ul>
    </section>

    <div class="back-link">
      <a href="/">&larr; Back to the calculator</a>
    </div>

  </main>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as unknown as Record<string, string>).toString(),
      });
      if (res.ok) {
        form.hidden = true;
        if (success) success.hidden = false;
      }
    } catch {
      // Fall back to native form submit if fetch fails
      form.submit();
    }
  });
</script>

<style>
  main {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  .card {
    background: #fff;
    border-radius: var(--radius, 12px);
    padding: 1.75rem 2rem;
    box-shadow: var(--shadow, 0 2px 12px rgba(0,0,0,0.08));
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  h2 {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--au-navy, #00205b);
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--au-navy, #00205b);
    border-left: 4px solid var(--au-gold, #ffcd00);
    padding-left: 0.75rem;
  }

  p {
    color: #374151;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .form-card form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
  }

  input[type="text"],
  input[type="email"],
  select,
  textarea {
    padding: 0.6rem 0.875rem;
    border: 1.5px solid #d1d5db;
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    color: #1a202c;
    background: #fff;
    transition: border-color 0.15s;
    width: 100%;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--au-navy, #00205b);
  }

  textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-primary {
    background: var(--au-navy, #00205b);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    align-self: flex-start;
  }

  .btn-primary:hover {
    background: #003087;
  }

  .success-msg {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: #f0fdf4;
    border: 1px solid #86efac;
    border-radius: 8px;
    padding: 1rem 1.25rem;
  }

  .success-icon {
    font-size: 1.5rem;
    color: #16a34a;
    font-weight: 700;
    flex-shrink: 0;
  }

  .success-msg strong {
    color: #15803d;
    display: block;
    margin-bottom: 0.2rem;
  }

  .success-msg p {
    color: #374151;
    margin: 0;
  }

  .info-list {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .info-list li {
    color: #374151;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .info-list a {
    color: var(--au-navy, #00205b);
    font-weight: 500;
  }

  .back-link {
    padding: 0.5rem 0 1rem;
  }

  .back-link a {
    color: var(--au-navy, #00205b);
    font-weight: 500;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .back-link a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .card { padding: 1.25rem 1rem; }
    .btn-primary { width: 100%; text-align: center; }
  }
</style>
